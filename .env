# Environment Configuration
NODE_ENV=development
PORT=3002
DATABASE_URL=postgresql://username:password@localhost:5432/your_database_name

# JWT Secrets (Generate strong, random strings for these)
JWT_ACCESS_SECRET=your_super_secret_access_token_key_here
JWT_RESET_SECRET=your_super_secret_reset_token_key_here

# JWT Expiration (Optional: Defaults to 7d and 15m if left out)
JWT_ACCESS_EXPIRES_IN=7d
JWT_RESET_EXPIRES_IN=15m

# Bcrypt Security (Optional: Defaults to 12 if left out)
BCRYPT_SALT_ROUNDS=12

# Application URLs
FRONTEND_URL=http://localhost:5173

# GitHub OAuth Credentials
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# GitHub Callback URL (Optional: Automatically generates if left blank)
# GITHUB_CALLBACK_URL=http://localhost:5173/api/github/auth/github/callback

# GitHub Personal Access Token (Optional: Defaults to the fallback in your code if left blank)
GITHUB_TOKEN=your_personal_access_token_here

# Redis Configuration (Uncomment this if you uncomment it in env.js)
# REDIS_URL=redis://localhost:6379